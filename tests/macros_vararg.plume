/// Test "Positionnal vararg 1"
macro foo(*arg)
    $(#arg)
$foo()\n
$foo(1)\n
$foo(1, 2)
/// Result
0
1
2
/// End

/// Test "Positionnal vararg 2"
macro foo(bar, *arg)
    $(#arg)
$foo(1)\n
$foo(1, 2)
/// Result
0
1
/// End

/// Test "Named vararg 1"
macro foo(*kw)
    $(kw.x or "")
$foo()
$foo(x: 5)
/// Result
5
/// End

/// Test "Named vararg 2"
macro foo(*kw)
    $(kw.x or "")
$foo()
$foo(x: 5)
/// Result
5
/// End

/// Test "Vararg capture"
macro foo(x:foo, *args)
    $(args[1])
$foo()
    - Bar
/// Result
Bar
/// End

/// Test "vararg not last"
macro foo(*kw, foo)
/// Error
Syntax error: vararg ('...') must be the last parameter in a parameter list.
File <string_1>, line n°1:
    macro foo(*kw, foo)
/// End

/// Test "Vararg inline"
foo = macro(*x)
/// Result
nil
/// End
