/// Test "Simple for"
for i=1, 5
    $i
/// Result
12345
/// End

/// Test "Simple while"
local i = 100
while i>0
    i = $(i-1)
$i
/// Result
0
/// End


/// Test "gmatch for"
for m in ("foo bar"):gmatch("%S+")
    $m
/// Result
foobar
/// End

/// Test "comprehensive list - sort off"
evens = for i=1, 5
    - $(i*2)

for _, x in ipairs(evens)
    $x
/// Result
246810
/// End