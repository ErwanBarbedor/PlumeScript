/// Test "Simple for"
for i=1, 5
    $i
/// Result
12345
/// End

/// Test "Simple while"
local $i = 10
while i>0
    $i
    i = $(i-1)
/// Result
10987654321
/// End

/// Test "Break loop"
local $i = 100
while i>0
    i = $(i-1)
    break
$i
/// Result
99
/// End

/// Test "gmatch for"
for m in ("foo bar"):gmatch("%S+")
    $m
/// Result
foobar
/// End

/// Test "comprehensive list - sort off"
evens = for i=1, 5
    - $(i*2)

for _, x in ipairs(evens)
    $x
/// Result
246810
/// End

/// Test "comment with loop"
for i=1, 2 // A comment
    $i
/// Result
12
/// End
