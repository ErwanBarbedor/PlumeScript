/// Test "Simple affectation 1"
$a = 1+1
$a
/// Result
2
/// End

/// Test "Simple affectation 2"
$a = math.cos(0)
$a
/// Result
1
/// End

/// Test "Simple key 1"
local t =
    $a: 1+1
$t.a
/// Result
2
/// End

/// Test "Simple key 2"
local t =
    $a: math.cos(0)
$t.a
/// Result
1
/// End

/// Test "Return"
local macro foo()
    $return 1+1
$foo()
/// Result
2
/// End