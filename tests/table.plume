/// Test "Simple list"
a =
    - Foo
    - Bar
for _, x in ipairs(a)
    $x
/// Result
FooBar
/// End

/// Test "Simple hash"
a =
    key: value

$(a.key)
/// Result
value
/// End

/// Test "List with computation"
a =
    i = 5
    - $i
    i = $(i*2)
    - $i

for _, x in ipairs(a)
    $x
/// Result
510
/// End

/// Test "One item list"
a =
    - Foo
$(a[1])
/// Result
Foo
/// End

/// Test "Mixed table 1"
a =
    - item
    key: value
$(a[1]) $(a.key)
/// Result
item value
/// End

/// Test "Mixed table 2"
a =
    - item
    local foo = bar
    key: value
$(a[1]) $(a.key)
/// Result
item value
/// End

/// Test "Empty line don't break scope"
a =
    - bar

    - baz
a[2] = $(a[2])
/// Result
a[2] = baz
/// End

/// Test "Macro in table"
lib =
    foo: macro ()
        bar

    double: macro (x)
        $x $x
$(lib.foo())
/// Result
bar
/// End

/// Test "Macro in table 2"
lib =
    init: macro (self, x)
        self.x = $x
void = $(lib:init(3))
$(lib.x)
/// Result
3
/// End

/// Test "Macro in table 3"
lib =
    foo: macro()
        bar

    double: macro(x)
        $x $x
$(lib.foo())
/// Result
bar
/// End

/// Test "Nested table 1"
t =
    -
        - Foo
        - Bar
$(t[1][1])
/// Result
Foo
/// End

/// Test "Nested table 2"
t =
    sub:
        - Foo
        - Bar
$(t.sub[1])
/// Result
Foo
/// End

/// Test "Nested table 3"
t =
    -
        x: 5
        y: 6
$(t[1].x)
/// Result
5
/// End

/// Test "Expand 1"
a =
    - foo
    - bar

b =
    - baz
    *a
$(b[2])
/// Result
foo
/// End

/// Test "Expand 2"
a =
    - foo
    - bar

b =
    *a
    - baz
$(b[2])
/// Result
bar
/// End

/// Test "Expand 3"
a =
    - foo
    - bar
    foo: bar

b =
    *a
    bar: foo
$b.foo $b.bar
/// Result
bar foo
/// End

/// Test "Expand 3"
a =
    - foo
    - bar
    foo: bar

b =
    *a
    foo: foo
$b.foo
/// Result
foo
/// End

/// Test "Expand 3"
a =
    - foo
    - bar
    foo: bar

b =
    foo: foo
    *a
$b.foo
/// Result
bar
/// End