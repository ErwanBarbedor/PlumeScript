/// Test "Simple macro and call"
macro foo()
    bar
$foo()
/// Result
bar
/// End

/// Test "Simple macro and call - with space"
macro foo ()
    bar
$foo()
/// Result
bar
/// End

/// Test "Simple local macro and call"
local macro foo()
    bar
$foo()
/// Result
bar
/// End

/// Test "Alternative declaration"
foo = macro ()
    bar
$foo()
/// Result
bar
/// End

/// Test "Alternative declaration - local"
local foo = macro ()
    bar
$foo()
/// Result
bar
/// End

/// Test "Macro return"
macro foo()
    return bar

$foo()
/// Result
bar
/// End

/// Test "Factorial"
macro fact(n)
    if n==0
        $return 1
    else
        $return n * fact(n-1)

10! = $fact(10)
/// Result
10! = 3628800
/// End

/// Test "Macro with parameters"
macro double(x)
    $x $x
$(double("foo"))
/// Result
foo foo
/// End

/// Test "Macro with default value 1"
macro foo(x: bar)
    $x
$foo()
/// Result
bar
/// End

/// Test "Macro with default value 2"
macro foo(x: bar)
    $x
$foo(x: baz)
/// Result
baz
/// End

/// Test "Extended Parameters - single value"
macro double(x)
    $x $x
$double()
    Foo
/// Result
Foo Foo
/// End

/// Test "Extended Parameters - double value"
macro keyvalue(key, value)
    $key \= $value
$keyvalue()
    - Foo
    - Bar
/// Result
Foo = Bar
/// End

/// Test "Extended Parameters - hash value 2"
macro foo(x: bar)
    $x
$foo()
    x: baz
/// Result
baz
/// End

/// Test "Extended Parameters - mixed args 1"
macro concat(x, y)
    $x$y
$concat(Foo)
    Bar
/// Result
FooBar
/// End

/// Test "Extended Parameters - mixed args 2"
macro concat(x, y)
    $x$y
$concat(Foo)
    - Bar
/// Result
FooBar
/// End

/// Test "Extended Parameters - mixed args 3"
macro concat(x, y, sep: -)
    $x$sep$y
$concat()
    - Foo
    - Bar
/// Result
Foo-Bar
/// End

/// Test "Extended Parameters - mixed args 4"
macro concat(x, y, sep: -)
    $x$sep$y
$concat()
    - Foo
    - Bar
    sep: =
/// Result
Foo=Bar
/// End

/// Test "Nested Call"
macro double(x)
    $x $x
$double($double(Foo))
/// Result
Foo Foo Foo Foo
/// End

/// Test "Extended Parameters & Affectation"
macro double(x)
    $x $x
a = $double()
    Foo
$a
/// Result
Foo Foo
/// End

/// Test "Void capture"
local x = 0
macro inc()
    x = $(x+1)
    Foo

$inc()\n
local void = $inc()
$x
/// Result
Foo
2
/// End

/// Test "Empty Macro"
macro void()
foo
/// Result
foo
/// End

/// Test "Space in argument list"
macro id(x, y)
    $x\n
    $y
$id(foo, bar)
/// Result
foo
bar
/// End

/// Test "Macro params are local"
macro id(x, y)
$id(foo)
$x
/// Result

/// End

/// Test "Macro expand 1"
macro id(x, y)
    $x - $y
t =
    - foo
    - bar
$id(*t)
/// Result
foo - bar
/// End

/// Test "Macro expand 1"
macro id(x, y)
    $x - $y
t =
    - foo
    - bar
$id()
    *t
/// Result
foo - bar
/// End

