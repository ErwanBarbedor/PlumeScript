/// Test "Load plume 1"
$require(tests/toImport/lib) // relative to launchTests.lua
/// Result
plume loaded
/// End

/// Test "Load plume 2"
foo = $require(tests/toImport/lib)
$foo
/// Result
plume loaded
/// End

/// Test "Load plume 3"
foo = $require(tests/toImport/lib)
$globalVar
/// Result
plume loaded (global)
/// End

/// Test "Load plume 4"
foo = $require(tests/toImport/lib)
$localVar
/// Result
nil
/// End

/// Test "Load lua 1"
$require(tests/toImport/lib, ext: lua)
/// Result
lua loaded
/// End

/// Test "Load lua 2"
$require(tests/toImport/lualib)
/// Result
lua loaded
/// End

/// Test "Load lua 3"
foo = $require(tests/toImport/lib, ext: lua)
$foo
/// Result
lua loaded
/// End

/// Test "Load lua 4"
foo = $require(tests/toImport/lib, ext: lua)
$globalVar
/// Result
lua loaded (global)
/// End

/// Test "Load lua 5"
foo = $require(tests/toImport/lib, ext: lua)
$localVar
/// Result
nil
/// End

/// Test "File not found"
$require(azag)
/// Result
nil
/// End