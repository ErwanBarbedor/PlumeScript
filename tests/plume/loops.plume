/// Test "Simple for"
for i=1, 5
    $i
/// Result
12345
/// End

/// Test "Simple while"
local i = 10
while i>0
    $i
    i = $(i-1)
/// Result
10987654321
/// End

/// Test "Break loop"
local i = 100
while i>0
    i = $(i-1)
    break
$i
/// Result
99
/// End

/// Test "Continue"
for i=1, 10
    if i>2 and i<9
        continue
    Line $i\n
/// Result
Line 1
Line 2
Line 9
Line 10

/// End

/// Test "Break outside loop"
local i = 100
break
$i
/// Error
Syntax error: 'BREAK' command cannot be use outside of a loop.
File <string_1>, line n°2:
    break
    ^^^^^
/// End

/// Test "Continue outside loop"
local i = 100
continue
$i
/// Error
Syntax error: 'CONTINUE' command cannot be use outside of a loop.
File <string_1>, line n°2:
    continue
    ^^^^^^^^
/// End

// // / Test "gmatch for"
// for m in ("foo bar"):gmatch("%S+")
//     $m
// /// Result
// foobar
// /// End

/// Test "comprehensive list - sort off"
evens =
    for i=1, 5
        - $(i*2)

for _, x in ipairs(evens)
    $x
/// Result
246810
/// End

/// Test "comment with loop"
for i=1, 2 // A comment
    $i
/// Result
12
/// End
