/// Test "Success 1"
macro foo(number x)
$foo(1)
/// Result

/// End

/// Test "Success 2"
macro foo(number x:0)
$foo(x: 1)
/// Result

/// End

/// Test "Success 3"
macro foo(number *x)
$foo()
    - 1
    - 2
    - 3
/// Result

/// End

/// Test "Success 4"
macro foo(number **x)
$foo()
    foo: 1
    bar: 2
    baz: 3
/// Result

/// End

/// Test "Success 5"
macro bar()
    bar
macro foo(macro m)
    $m()
$foo($bar)
/// Result
bar
/// End

