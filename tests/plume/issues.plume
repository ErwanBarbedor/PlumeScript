/// Test "Issue 2"
macro foo(x, y)
    $x, $y
$foo(bar, baz)
/// Result
bar, baz
/// End

/// Test "Issue 3"
macro foo(x)
    $x
($foo(x))\n
$foo((x))
/// Result
(x)
(x)
/// End

/// Test "Issue 4"
macro foo(*args)
    $(#args)
t1 =
    - foo
t2 =
    - bar
$foo(*t1, *t2)
/// Result
2
/// End

/// Test "Issue 5"
macro foo()
  )
macro foo() )
/// Result
nil
/// End

/// Test "Issue 6"
macro foo(**kw)
  $bar()
    k:
      - )
      **t
/// Result
nil
/// End

