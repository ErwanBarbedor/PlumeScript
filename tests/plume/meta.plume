/// Test "@mul"
t =
    - 1
    - 2
    @mul: macro(n)
        for k, v in enumerate(self)
            self[k] *= $n
void $(t * 5)
$t[1]\n
$t[2]
/// Result
5
10
/// End

/// Test "@mul (reverse)"
t =
    - 1
    - 2
    @mul: macro(n)
        for k, v in enumerate(self)
            self[k] *= $n
void $(5 * t)
$t[1]\n
$t[2]
/// Result
5
10
/// End

/// Test "@tostring"
t =
    foo: bar
    @tostring: macro()
        $self.foo
$t
/// Result
bar
/// End

/// Test "@call 1"
t =
    foo: bar
    @call: macro()
        $self.foo
$t()
/// Result
bar
/// End

/// Test "@call 2"
t =
    foo: bar
    @call: macro(x)
        $x is $self.foo
$t(foo)
/// Result
foo is bar
/// End

/// Test "@call 3"
t =
    foo: bar
    @call: macro(x: bar)
        $x is $self.foo
$t(x: foo)
/// Result
foo is bar
/// End


/// Test "Mixed eval/meta"
t =
    @$add: 5
/// Error
Syntax error: a hash key cannot both be a meta field and be evaluated.
File <string_1>, line n°2:
    @$add: 5
     ^
/// End