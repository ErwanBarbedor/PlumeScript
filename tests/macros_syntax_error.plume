/// Test "Missing comma"
macro foo(x y)
/// Error
Syntax error: expected a comma, not "y".
File <string_1>, line n°1:
    macro foo(x y)
/// End

/// Test "Expecting a name 1"
macro foo($)
/// Error
Syntax error: expected parameter name, not "$".
File <string_1>, line n°1:
    macro foo($)
/// End

/// Test "Expecting a name 2"
macro foo(x, $)
/// Error
Syntax error: expected parameter name, not "$".
File <string_1>, line n°1:
    macro foo(x, $)
/// End

/// Test "Expecting a name 3"
macro foo(x, !x)
/// Error
Syntax error: expected parameter name, not "!".
File <string_1>, line n°1:
    macro foo(x, !x)
/// End

/// Test "Expecting a name 4"
macro foo(x,)
/// Error
Syntax error: expected parameter name after ",", not ")".
File <string_1>, line n°1:
    macro foo(x,)
/// End

/// Test "Expecting a name 5"
macro foo(x, )
/// Error
Syntax error: expected parameter name after ",", not ")".
File <string_1>, line n°1:
    macro foo(x, )
/// End